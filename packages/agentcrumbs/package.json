{
  "name": "agentcrumbs",
  "version": "0.3.1",
  "description": "Debug mode for any agent.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "agentcrumbs": "./dist/cli/index.js",
    "intent": "./bin/intent.js"
  },
  "files": [
    "dist",
    "skills",
    "bin",
    "!skills/_artifacts"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/triggerdotdev/agentcrumbs.git",
    "directory": "packages/agentcrumbs"
  },
  "homepage": "https://agentcrumbs.dev",
  "bugs": {
    "url": "https://github.com/triggerdotdev/agentcrumbs/issues"
  },
  "intent": {
    "version": 1,
    "repo": "triggerdotdev/agentcrumbs",
    "docs": "https://agentcrumbs.dev/docs"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npx @tanstack/intent@latest validate"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "keywords": [
    "debug",
    "tracing",
    "agents",
    "ai",
    "logging",
    "observability",
    "claude",
    "cursor",
    "copilot"
  ]
}
