{
  "name": "agentcrumbs",
  "version": "0.4.0",
  "description": "Debug mode for any agent.",
  "tshy": {
    "exports": {
      ".": "./src/index.ts"
    },
    "exclude": [
      "src/__tests__/**/*"
    ]
  },
  "bin": {
    "agentcrumbs": "./dist/esm/cli/index.js",
    "intent": "./bin/intent.js"
  },
  "files": [
    "dist",
    "skills",
    "bin",
    "!skills/_artifacts"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/triggerdotdev/agentcrumbs.git",
    "directory": "packages/agentcrumbs"
  },
  "homepage": "https://agentcrumbs.dev",
  "bugs": {
    "url": "https://github.com/triggerdotdev/agentcrumbs/issues"
  },
  "intent": {
    "version": 1,
    "repo": "triggerdotdev/agentcrumbs",
    "docs": "https://agentcrumbs.dev/docs"
  },
  "scripts": {
    "build": "tshy",
    "dev": "tshy --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npx @tanstack/intent@latest validate"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tshy": "^3.3.2",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "keywords": [
    "debug",
    "tracing",
    "agents",
    "ai",
    "logging",
    "observability",
    "claude",
    "cursor",
    "copilot"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/commonjs/index.d.ts",
        "default": "./dist/commonjs/index.js"
      }
    }
  },
  "main": "./dist/commonjs/index.js",
  "types": "./dist/commonjs/index.d.ts",
  "module": "./dist/esm/index.js"
}
